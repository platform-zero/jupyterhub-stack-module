{
  "schemaVersion": 1,
  "id": "jupyterhub",
  "repo": "jupyterhub-stack-module",
  "runtimeId": "jupyterhub",
  "lifecycle": "active",
  "dependencies": [
    "stack-foundation"
  ],
  "runtimeDependencies": [
    "stack-foundation",
    "jupyter-notebook",
    "postgres-ssd",
    "valkey",
    "docker-proxy"
  ],
  "contracts": [
    "module-contract"
  ],
  "smoke": "external-only",
  "smokeUnsupportedReason": "requires generated bundle context, deployed networking, secrets, or service dependencies",
  "overlays": [
    "stack.compose/jupyterhub.yml",
    "stack.config/jupyterhub",
    "stack.containers/jupyterhub"
  ],
  "testAssets": []
}
